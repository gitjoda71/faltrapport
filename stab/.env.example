# Kopiera den här filen till .env och fyll i dina värden
# cp .env.example .env

# Token från Obsidian → Local REST API-pluginet → Settings
OBSIDIAN_TOKEN=byt-ut-mig

# Adressen till Obsidian Local REST API (standardport 27123)
OBSIDIAN_API=http://localhost:27123

# Sökväg inuti valvet dit rapportnoterna skrivs
RAPPORT_DIR=Stabssystem/Rapporter
